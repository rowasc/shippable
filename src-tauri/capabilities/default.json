{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:webview:allow-set-webview-zoom",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/shippable-server",
          "sidecar": true,
          "args": false
        }
      ]
    },
    "shell:allow-open"
  ]
}
