#!/usr/bin/env bash
# Claude Code UserPromptSubmit hook for Shippable.
#
# When the reviewer types a message in the agent-context panel, the Shippable
# server writes it to <worktree>/.shippable/inbox.md. This hook fires on the
# agent's next prompt boundary, reads that file, prepends its contents to the
# user prompt (wrapped in a <reviewer-feedback> tag so the agent can see
# where the input came from), and deletes the file so it doesn't replay.
#
# Install: copy this script somewhere on $PATH, make it executable, then add
# to your Claude Code settings.json:
#
#   {
#     "hooks": {
#       "UserPromptSubmit": [{ "command": "/absolute/path/to/shippable-inbox-hook" }]
#     }
#   }
#
# Latency model: feedback is delivered on the agent's *next* prompt boundary —
# not mid-turn. For the design rationale see docs/concepts/agent-context.md.

set -euo pipefail

# Read the JSON event from stdin and extract `cwd`. Python is on every macOS
# install; we don't want to require jq.
INPUT="$(cat)"
CWD="$(printf '%s' "$INPUT" | python3 -c "import sys, json
try:
    print(json.load(sys.stdin).get('cwd', ''))
except Exception:
    pass")"

if [ -z "$CWD" ]; then
  exit 0
fi

INBOX="$CWD/.shippable/inbox.md"
if [ ! -s "$INBOX" ]; then
  exit 0
fi

# stdout from a UserPromptSubmit hook is treated as additional context the
# model sees prepended to the user's prompt. Wrap so the agent can tell this
# came from the reviewer, not the user driving the session.
printf '<reviewer-feedback from="shippable">\n'
cat "$INBOX"
printf '\n</reviewer-feedback>\n'

# Consume the inbox so the same message doesn't replay on every prompt.
rm -f "$INBOX"
