{
  "name": "server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "GPL-2.0-or-later",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:sidecar": "bun build --compile --minify --sourcemap --target=bun-darwin-arm64 ./src/index.ts --outfile ../src-tauri/binaries/shippable-server-aarch64-apple-darwin"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "vitest": "^4.1.5"
  }
}
